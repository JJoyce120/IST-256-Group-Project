<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Symposium | Register</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
    .navbar {
        background-color: #041E42;
    }
    footer {
        background-color: #041E42;
        color: white;
        padding: 20px;
        text-align: center;
        margin-top: 40px;
    }
    .registration-header {
        background-color: #f8f9fa;
        padding: 30px;
        margin-bottom: 20px;
    }
    .card-header {
        background-color: #041E42;
        color: white;
        font-weight: bold;
    }
    .btn-psu {
        background-color: #041E42;
        color: white;
    }
    .btn-psu:hover {
        background-color: #02305c;
        color: white;
    }
</style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="index.html">PSU IST SYMPOSIUM</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="index.html">Home</a>
                <a class="nav-link active" href="register.html">Register</a>
            </div>
        </div>
    </nav>

    <header class="registration-header text-center">
        <div class="container">
            <h2 class="display-5 fw-bold">Attendee Registration</h2>
            <p class="lead">Manage your symposium participants here.</p>
        </div>
    </header>

    <div class="container">
        <div class="row">
            <div class="col-lg-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header text-center">Form</div>
                    <div class="card-body">
                        <form id="memberForm">
                            <div class="mb-3">
                                <label for="name" class="form-label">Name</label>
                                <input type="text" class="form-control" id="name" required>
                            </div>
                            <div class="mb-3">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email" required>
                            </div>
                            <div class="mb-3">
                                <label for="age" class="form-label">Age/Year</label>
                                <input type="text" class="form-control" id="age" required>
                            </div>
                            <div class="mb-3">
                                <label for="affiliation" class="form-label">Affiliation</label>
                                <input type="text" class="form-control" id="affiliation" required>
                            </div>
                            <div class="mb-3">
                                <label for="phone" class="form-label">Phone</label>
                                <input type="text" class="form-control" id="phone">
                            </div>
                            <button type="submit" class="btn btn-psu w-100">Register</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-header">Submitted Members</div>
                    <div class="card-body p-0">
                        <table class="table table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Age</th>
                                    <th>Affiliation</th>
                                    <th>Phone</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="memberTableBody">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <p>Penn State College of Information Sciences and Technology</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="js/validation.js"></script>
</body>
</html>
